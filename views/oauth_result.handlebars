<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{{title}}</title>
    <style>
      body { font-family: system-ui, -apple-system, Roboto, 'Helvetica Neue', Arial; padding: 2rem; background:#fafafa; color:#222 }
      .card { max-width:700px; margin:2rem auto; background:#fff; border-radius:8px; padding:1.5rem; box-shadow:0 6px 18px rgba(0,0,0,0.06) }
      .success { color: #0b6623; font-weight:600 }
      .error { color: #b22222; font-weight:600 }
      pre { background:#f6f8fa; padding:0.75rem; border-radius:6px; overflow:auto }
      a.button { display:inline-block; margin-top:1rem; padding:0.5rem 0.9rem; background:#2563eb; color:#fff; border-radius:6px; text-decoration:none }
    </style>
  </head>
  <body>
    <div class="card">
      <h1>{{title}}</h1>
      <p class="{{#if success}}success{{else}}error{{/if}}">{{message}}</p>
      {{#if details}}
        <h3>Details</h3>
        <pre>{{details}}</pre>
      {{/if}}
      <a class="button" href="/">Return to dashboard</a>
    </div>
  </body>
</html>