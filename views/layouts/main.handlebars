<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">    <title>{{title}}</title>
    <script>
      (function () {
        try {
          const savedTheme = localStorage.getItem('hilayuval-theme');
          const systemDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
          const theme = savedTheme || (systemDark ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (_) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;450;500;600&family=Heebo:wght@300;400;500&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
    <link href="/css/custom.css" rel="stylesheet"> {{! Added custom CSS }}
    <link href="/css/portfolio.css" rel="stylesheet"> {{! Portfolio light accordion }}
    {{#if bunny_stream_library_id}}
    <meta name="bunny-stream-library" content="{{bunny_stream_library_id}}">
    {{/if}}
    {{!-- Bunny tus (resumable) endpoint pattern (informational) --}}
    {{#if bunny_stream_library_id}}
    <meta name="bunny-tus-endpoint" content="https://video.bunnycdn.com/library/{{bunny_stream_library_id}}/videos">
    {{/if}}
    {{#if ga_measurement_id}}
    <script async src="https://www.googletagmanager.com/gtag/js?id={{ga_measurement_id}}"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '{{ga_measurement_id}}');
    </script>
    {{/if}}
</head>
<body>
    {{> header}}
    {{> breadcrumbs}}
    {{{body}}}
    <style>
      html[data-theme='dark'] body {
        background: #12161d !important;
        color: #e9edf2 !important;
      }

      html[data-theme='dark'] .navbar,
      html[data-theme='dark'] .navbar-light,
      html[data-theme='dark'] .bg-light {
        background: #1a212c !important;
        border-color: #2f3a48 !important;
      }

      html[data-theme='dark'] .container,
      html[data-theme='dark'] .container-fluid,
      html[data-theme='dark'] .text-muted {
        color: #c7d0da !important;
      }

      html[data-theme='dark'] .card,
      html[data-theme='dark'] .card-body,
      html[data-theme='dark'] .accordion-item,
      html[data-theme='dark'] .accordion-body,
      html[data-theme='dark'] .table-responsive {
        background: #1b2430 !important;
        color: #e9edf2 !important;
        border-color: #2f3a48 !important;
      }

      html[data-theme='dark'] .table > :not(caption) > * > * {
        background-color: #1b2430 !important;
        color: #e9edf2 !important;
        border-color: #2f3a48 !important;
      }

      html[data-theme='dark'] .form-control,
      html[data-theme='dark'] .form-select,
      html[data-theme='dark'] textarea.form-control {
        background: #121821 !important;
        color: #e9edf2 !important;
        border-color: #3a4758 !important;
      }

      html[data-theme='dark'] .form-control::placeholder {
        color: #91a1b4 !important;
      }

      html[data-theme='dark'] .btn-outline-secondary,
      html[data-theme='dark'] .btn-outline-primary,
      html[data-theme='dark'] .btn-outline-danger,
      html[data-theme='dark'] .btn-outline-success {
        color: #d7e0ea !important;
        border-color: #5a6a7d !important;
      }

      html[data-theme='dark'] #auditions-list-view,
      html[data-theme='dark'] #auditions-list-view .card,
      html[data-theme='dark'] #auditions-list-view .table-responsive,
      html[data-theme='dark'] #auditions-list-view .auditions-list-table,
      html[data-theme='dark'] #auditions-list-view .auditions-list-table thead,
      html[data-theme='dark'] #auditions-list-view .auditions-list-table tbody,
      html[data-theme='dark'] #auditions-list-view .auditions-list-table tr,
      html[data-theme='dark'] #auditions-list-view .auditions-list-table td,
      html[data-theme='dark'] #auditions-list-view .auditions-list-table th {
        background: #1b2430 !important;
        background-image: none !important;
      }
    </style>
    {{> footer}}
    {{> flash}}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    {{!-- tus-js-client for direct Bunny TUS uploads --}}
    <script src="https://cdn.jsdelivr.net/npm/tus-js-client@3.1.3/dist/tus.min.js" crossorigin="anonymous"></script>
    <script src="/js/main.js"></script>
    <script>
      (function () {
        const applyTheme = (theme) => {
          document.documentElement.setAttribute('data-theme', theme);
          const iconClass = theme === 'dark' ? 'fa-sun' : 'fa-moon';
          const toggleButtons = document.querySelectorAll('[data-theme-toggle]');
          toggleButtons.forEach((button) => {
            const icon = button.querySelector('[data-theme-icon]');
            if (!icon) return;
            icon.classList.remove('fa-moon', 'fa-sun');
            icon.classList.add(iconClass);
          });
        };

        const currentTheme = document.documentElement.getAttribute('data-theme') || 'light';
        applyTheme(currentTheme);

        const toggleButtons = document.querySelectorAll('[data-theme-toggle]');
        toggleButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const current = document.documentElement.getAttribute('data-theme') || 'light';
            const next = current === 'dark' ? 'light' : 'dark';
            applyTheme(next);
            try {
              localStorage.setItem('hilayuval-theme', next);
            } catch (_) {}
          });
        });
      })();
    </script>
</body>
</html>
