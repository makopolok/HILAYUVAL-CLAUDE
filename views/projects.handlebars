{{!-- views/projects.handlebars --}}
<div class="container mt-5">
  <h1 class="display-4 mb-4">Projects</h1>
  <a href="/projects/create" class="btn btn-outline-success mb-3">Create New Project</a>
  <form class="row g-3 mb-4" method="GET" action="">
    <div class="col-md-8 col-lg-6">
      <input type="text" class="form-control" name="term" placeholder="Search by performer or email" value="{{query.term}}">
    </div>
    <div class="col-md-4 col-lg-3 d-flex align-items-center gap-2">
      <button type="submit" class="btn btn-outline-danger">Global Search</button>
      <a href="/projects" class="btn btn-outline-secondary">Clear</a>
    </div>
  </form>
  {{#if searchPerformed}}
  <div class="card mb-4">
    <div class="card-header">Audition Search Results</div>
    <div class="card-body">
      {{#if searchError}}
        <div class="alert alert-danger mb-0">{{searchError}}</div>
      {{else}}
        {{#if searchResults.length}}
          <div class="table-responsive">
            <table class="table table-striped">
              <thead>
                <tr>
                  <th>Performer</th>
                  <th>Email</th>
                  <th>Role</th>
                  <th>Project</th>
                  <th>Submitted</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                {{#each searchResults}}
                <tr>
                  <td>{{this.display_name}}</td>
                  <td>{{this.email}}</td>
                  <td>{{this.role}}</td>
                  <td>{{this.project_name}}</td>
                  <td>{{this.created_at_formatted}}</td>
                  <td>
                    <a href="/projects/{{this.project_id}}/auditions" class="btn btn-outline-primary btn-sm">View Auditions</a>
                  </td>
                </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
        {{else}}
          <p class="mb-0">No auditions matched your search.</p>
        {{/if}}
      {{/if}}
    </div>
  </div>
  {{/if}}
  {{#if projects.length}}
    <table class="table table-bordered table-hover">
      <thead>
        <tr>
          <th>Name</th>
          <th>Description</th>
          <th>Created</th>
          <th>Audition Form Link</th>
          <th>Audition Playlist</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each projects}}
        <tr class="project-tag-row" data-project-id="{{this.id}}" data-tag-color="{{this.tag_color}}" data-tag-color-bg="{{this.tag_color_bg}}" data-tag-color-hover="{{this.tag_color_hover}}"{{#if this.tag_color_bg}} style="--bs-table-bg:{{this.tag_color_bg}};--bs-table-hover-bg:{{this.tag_color_hover}};"{{/if}}>
          <td>{{this.name}}</td>
          <td>{{this.description}}</td>
          <td>{{this.createdAt}}</td>
          <td>
            <a href="/audition/{{this.id}}" target="_blank">/audition/{{this.id}}</a>
          </td>
          <td>
            <a href="/projects/{{this.id}}/auditions" class="btn btn-outline-danger btn-sm">View Auditions</a>
          </td>
          <td>
            <a href="/projects/{{this.id}}/edit" class="btn btn-outline-secondary btn-sm">Edit</a>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  {{else}}
    <p>No projects found.</p>
  {{/if}}
  
  <hr class="my-4">
  {{! Debug: Show raw deploymentInfo object }}
  {{#if deploymentInfo}}
  <div class="alert alert-warning small mb-2">
    <strong>DEBUG - Raw data:</strong> 
    Commit: {{deploymentInfo.commit}}, Version: {{deploymentInfo.version}}, Branch: {{deploymentInfo.branch}}, Date: {{deploymentInfo.deployDate}}
  </div>
  {{else}}
  <div class="alert alert-danger small mb-2">
    <strong>DEBUG:</strong> deploymentInfo is null/undefined!
  </div>
  {{/if}}
  
  <div class="alert alert-info small mb-3">
    <strong>Version Info:</strong> 
    Commit: {{deploymentInfo.commit}} | 
    Version: {{deploymentInfo.version}} | 
    Branch: {{deploymentInfo.branch}} | 
    Deployed: {{deploymentInfo.deployDate}}
  </div>
</div>

<div id="project-tag-menu" class="project-tag-menu d-none" role="menu" aria-label="Set project row color">
  <button type="button" class="project-tag-menu-item" data-tag-color="">
    <span class="project-tag-dot project-tag-dot-none"></span>
    No color
  </button>
  <button type="button" class="project-tag-menu-item" data-tag-color="gray"><span class="project-tag-dot tag-gray"></span>Gray</button>
  <button type="button" class="project-tag-menu-item" data-tag-color="red"><span class="project-tag-dot tag-red"></span>Red</button>
  <button type="button" class="project-tag-menu-item" data-tag-color="orange"><span class="project-tag-dot tag-orange"></span>Orange</button>
  <button type="button" class="project-tag-menu-item" data-tag-color="yellow"><span class="project-tag-dot tag-yellow"></span>Yellow</button>
  <button type="button" class="project-tag-menu-item" data-tag-color="green"><span class="project-tag-dot tag-green"></span>Green</button>
  <button type="button" class="project-tag-menu-item" data-tag-color="blue"><span class="project-tag-dot tag-blue"></span>Blue</button>
  <button type="button" class="project-tag-menu-item" data-tag-color="purple"><span class="project-tag-dot tag-purple"></span>Purple</button>
</div>

<script>
function applyProjectTagColor(row, tagColor, bgColor, hoverColor) {
  row.dataset.tagColor = tagColor || '';
  row.dataset.tagColorBg = bgColor || '';
  row.dataset.tagColorHover = hoverColor || '';
  if (bgColor) {
    row.style.setProperty('--bs-table-bg', bgColor);
    row.style.setProperty('--bs-table-hover-bg', hoverColor || bgColor);
  } else {
    row.style.removeProperty('--bs-table-bg');
    row.style.removeProperty('--bs-table-hover-bg');
  }
}

document.addEventListener('DOMContentLoaded', function () {
  const menu = document.getElementById('project-tag-menu');
  const rows = document.querySelectorAll('.project-tag-row');
  if (!menu || !rows.length) return;

  let activeRow = null;

  const hideMenu = () => {
    menu.classList.add('d-none');
    activeRow = null;
  };

  const showMenu = (event, row) => {
    menu.classList.remove('d-none');
    menu.style.left = `${event.pageX}px`;
    menu.style.top = `${event.pageY}px`;
    activeRow = row;
  };

  rows.forEach((row) => {
    row.addEventListener('contextmenu', (event) => {
      event.preventDefault();
      showMenu(event, row);
    });
  });

  menu.addEventListener('click', async (event) => {
    const item = event.target.closest('.project-tag-menu-item');
    if (!item || !activeRow) return;
    const selectedRow = activeRow;
    const projectId = activeRow.dataset.projectId;
    const tagColor = (item.dataset.tagColor || '').trim().toLowerCase();
    hideMenu();

    try {
      const response = await fetch(`/projects/${projectId}/tag-color`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ tagColor: tagColor || null })
      });
      const payload = await response.json().catch(() => ({}));
      if (!response.ok || !payload.ok) {
        throw new Error(payload.error || 'Failed to save color');
      }
      applyProjectTagColor(selectedRow, payload.tagColor || '', payload.tagColorBg || '', payload.tagColorHover || '');
    } catch (err) {
      console.error('[PROJECT_TAG_COLOR_SAVE_ERROR]', err);
      alert('Could not save project color. Please try again.');
    }
  });

  document.addEventListener('click', (event) => {
    if (!menu.contains(event.target)) hideMenu();
  });
  window.addEventListener('scroll', hideMenu, true);
  window.addEventListener('resize', hideMenu);
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') hideMenu();
  });
});
</script>

<style>
.project-tag-menu {
  position: absolute;
  z-index: 2100;
  min-width: 170px;
  background: #fff;
  border: 1px solid #ddd;
  border-radius: 8px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.16);
  padding: 6px;
}

.project-tag-menu-item {
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  border: 0;
  background: transparent;
  text-align: left;
  padding: 7px 8px;
  border-radius: 6px;
  font-size: 14px;
}

.project-tag-menu-item:hover {
  background: #f2f4f7;
}

.project-tag-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  display: inline-block;
  flex-shrink: 0;
}

.project-tag-dot-none {
  border: 1px solid #adb5bd;
  background: #fff;
}

.tag-gray { background: #6c757d; }
.tag-red { background: #e03131; }
.tag-orange { background: #f08c00; }
.tag-yellow { background: #f59f00; }
.tag-green { background: #2f9e44; }
.tag-blue { background: #1c7ed6; }
.tag-purple { background: #9c36b5; }

/* Override Bootstrap 5 CSS vars so its box-shadow overlay uses our colors */
tr.project-tag-row.tag-color-gray   { --bs-table-bg: #f1f3f5; --bs-table-hover-bg: #e9ecef; --bs-table-striped-bg: #f1f3f5; }
tr.project-tag-row.tag-color-red    { --bs-table-bg: #fff5f5; --bs-table-hover-bg: #ffe3e3; --bs-table-striped-bg: #fff5f5; }
tr.project-tag-row.tag-color-orange { --bs-table-bg: #fff4e6; --bs-table-hover-bg: #ffe8cc; --bs-table-striped-bg: #fff4e6; }
tr.project-tag-row.tag-color-yellow { --bs-table-bg: #fff9db; --bs-table-hover-bg: #fff3bf; --bs-table-striped-bg: #fff9db; }
tr.project-tag-row.tag-color-green  { --bs-table-bg: #ebfbee; --bs-table-hover-bg: #d3f9d8; --bs-table-striped-bg: #ebfbee; }
tr.project-tag-row.tag-color-blue   { --bs-table-bg: #e7f5ff; --bs-table-hover-bg: #d0ebff; --bs-table-striped-bg: #e7f5ff; }
tr.project-tag-row.tag-color-purple { --bs-table-bg: #f8f0fc; --bs-table-hover-bg: #f3d9fa; --bs-table-striped-bg: #f8f0fc; }
</style>
