{{!-- views/projects.handlebars --}}
<div class="container mt-5">
  <h1 class="display-4 mb-4">Projects</h1>
  <a href="/projects/create" class="btn btn-outline-success mb-3">Create New Project</a>
  <form class="row g-3 mb-4" method="GET" action="">
    <div class="col-md-8 col-lg-6">
      <input type="text" class="form-control" name="term" placeholder="Search by performer or email" value="{{query.term}}">
    </div>
    <div class="col-md-4 col-lg-3 d-flex align-items-center gap-2">
      <button type="submit" class="btn btn-outline-danger">Global Search</button>
      <a href="/projects" class="btn btn-outline-secondary">Clear</a>
    </div>
  </form>
  {{#if searchPerformed}}
  <div class="card mb-4">
    <div class="card-header">Audition Search Results</div>
    <div class="card-body">
      {{#if searchError}}
        <div class="alert alert-danger mb-0">{{searchError}}</div>
      {{else}}
        {{#if searchResults.length}}
          <div class="table-responsive">
            <table class="table table-striped">
              <thead>
                <tr>
                  <th>Performer</th>
                  <th>Email</th>
                  <th>Role</th>
                  <th>Project</th>
                  <th>Submitted</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                {{#each searchResults}}
                <tr>
                  <td>{{this.display_name}}</td>
                  <td>{{this.email}}</td>
                  <td>{{this.role}}</td>
                  <td>{{this.project_name}}</td>
                  <td>{{this.created_at_formatted}}</td>
                  <td>
                    <a href="/projects/{{this.project_id}}/auditions" class="btn btn-outline-primary btn-sm">View Auditions</a>
                  </td>
                </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
        {{else}}
          <p class="mb-0">No auditions matched your search.</p>
        {{/if}}
      {{/if}}
    </div>
  </div>
  {{/if}}
  {{#if projects.length}}
    <table class="table table-bordered custom-hover-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Description</th>
          <th>Created</th>
          <th>Audition Form Link</th>
          <th>Audition Playlist</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each projects}}
        <tr class="project-tag-row{{#if this.tag_color}} tag-color-{{this.tag_color}}{{/if}}" data-project-id="{{this.id}}" data-tag-color="{{this.tag_color}}">
          <td>{{this.name}}</td>
          <td>{{this.description}}</td>
          <td>{{this.createdAt}}</td>
          <td>
            <a href="/audition/{{this.id}}" target="_blank">/audition/{{this.id}}</a>
          </td>
          <td>
            <a href="/projects/{{this.id}}/auditions" class="btn btn-outline-danger btn-sm">View Auditions</a>
          </td>
          <td>
            <a href="/projects/{{this.id}}/edit" class="btn btn-outline-secondary btn-sm">Edit</a>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  {{else}}
    <p>No projects found.</p>
  {{/if}}
  
  <hr class="my-4">
  {{! Debug: Show raw deploymentInfo object }}
  {{#if deploymentInfo}}
  <div class="alert alert-warning small mb-2">
    <strong>DEBUG - Raw data:</strong> 
    Commit: {{deploymentInfo.commit}}, Version: {{deploymentInfo.version}}, Branch: {{deploymentInfo.branch}}, Date: {{deploymentInfo.deployDate}}
  </div>
  {{else}}
  <div class="alert alert-danger small mb-2">
    <strong>DEBUG:</strong> deploymentInfo is null/undefined!
  </div>
  {{/if}}
  
  <div class="alert alert-info small mb-3">
    <strong>Version Info:</strong> 
    Commit: {{deploymentInfo.commit}} | 
    Version: {{deploymentInfo.version}} | 
    Branch: {{deploymentInfo.branch}} | 
    Deployed: {{deploymentInfo.deployDate}}
  </div>
</div>

<div id="project-tag-menu" class="project-tag-menu d-none" role="menu" aria-label="Set project row color">
  <button type="button" class="project-tag-menu-item" data-tag-color="">
    <span class="project-tag-dot project-tag-dot-none"></span>
    No color
  </button>
  <button type="button" class="project-tag-menu-item" data-tag-color="gray"><span class="project-tag-dot tag-gray"></span>Gray</button>
  <button type="button" class="project-tag-menu-item" data-tag-color="red"><span class="project-tag-dot tag-red"></span>Red</button>
  <button type="button" class="project-tag-menu-item" data-tag-color="orange"><span class="project-tag-dot tag-orange"></span>Orange</button>
  <button type="button" class="project-tag-menu-item" data-tag-color="yellow"><span class="project-tag-dot tag-yellow"></span>Yellow</button>
  <button type="button" class="project-tag-menu-item" data-tag-color="green"><span class="project-tag-dot tag-green"></span>Green</button>
  <button type="button" class="project-tag-menu-item" data-tag-color="blue"><span class="project-tag-dot tag-blue"></span>Blue</button>
  <button type="button" class="project-tag-menu-item" data-tag-color="purple"><span class="project-tag-dot tag-purple"></span>Purple</button>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const TAG_COLOR_MAP = {
    gray: '#6c757d',
    red: '#e03131',
    orange: '#f08c00',
    yellow: '#f59f00',
    green: '#2f9e44',
    blue: '#1c7ed6',
    purple: '#9c36b5'
  };

  function applyColorStripe(row, colorName) {
    if (!colorName || !TAG_COLOR_MAP[colorName]) {
      row.style.backgroundImage = '';
      return;
    }
    const colorHex = TAG_COLOR_MAP[colorName];
    const gradient = `linear-gradient(90deg, ${colorHex} 0%, ${colorHex} 6px, transparent 6px)`;
    
    // Apply to row AND all cells with !important inline styles to defeat Bootstrap table-hover
    row.style.cssText = `background-image: ${gradient} !important; background-repeat: repeat-y !important; background-attachment: local !important;`;
    
    // Also apply to each cell to ensure it persists
    row.querySelectorAll('td').forEach(cell => {
      cell.style.backgroundColor = 'transparent';
    });
  }

  document.querySelectorAll('.project-tag-row').forEach(function (row) {
    const colorName = row.dataset.tagColor;
    if (colorName) {
      applyColorStripe(row, colorName);
    }
  });

  const menu = document.getElementById('project-tag-menu');
  if (!menu) return;
  let activeRow = null;

  const hideMenu = () => { menu.classList.add('d-none'); activeRow = null; };
  const showMenu = (e, row) => {
    menu.classList.remove('d-none');
    menu.style.left = e.pageX + 'px';
    menu.style.top  = e.pageY + 'px';
    activeRow = row;
  };

  document.querySelectorAll('.project-tag-row').forEach(function (row) {
    row.addEventListener('contextmenu', function (e) { e.preventDefault(); showMenu(e, row); });
  });

  menu.addEventListener('click', async function (e) {
    const item = e.target.closest('.project-tag-menu-item');
    if (!item || !activeRow) return;
    const row = activeRow;
    const projectId = row.dataset.projectId;
    const tagColor = (item.dataset.tagColor || '').trim().toLowerCase();
    hideMenu();

    try {
      const res = await fetch('/projects/' + projectId + '/tag-color', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ tagColor: tagColor || null })
      });
      const payload = await res.json().catch(function () { return {}; });
      if (!res.ok || !payload.ok) throw new Error(payload.error || 'Failed');
      row.dataset.tagColor = payload.tagColor || '';
      applyColorStripe(row, payload.tagColor || '');
    } catch (err) {
      console.error('[TAG_COLOR]', err);
      alert('Could not save color. Please try again.');
    }
  });

  document.addEventListener('click', function (e) { if (!menu.contains(e.target)) hideMenu(); });
  window.addEventListener('scroll', hideMenu, true);
  window.addEventListener('resize', hideMenu);
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape') hideMenu(); });
});
</script>

<style>
.project-tag-menu {
  position: absolute;
  z-index: 2100;
  min-width: 170px;
  background: #fff;
  border: 1px solid #ddd;
  border-radius: 8px;
  box-shadow: 0 8px 24px rgba(0,0,0,.16);
  padding: 6px;
}
.project-tag-menu-item {
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  border: 0;
  background: transparent;
  text-align: left;
  padding: 7px 8px;
  border-radius: 6px;
  font-size: 14px;
  cursor: pointer;
}
.project-tag-menu-item:hover { background: #f2f4f7; }
.project-tag-dot {
  width: 12px; height: 12px;
  border-radius: 50%;
  display: inline-block;
  flex-shrink: 0;
}
.project-tag-dot-none { border: 1px solid #adb5bd; background: #fff; }
.tag-gray   { background: #6c757d; }
.tag-red    { background: #e03131; }
.tag-orange { background: #f08c00; }
.tag-yellow { background: #f59f00; }
.tag-green  { background: #2f9e44; }
.tag-blue   { background: #1c7ed6; }
.tag-purple { background: #9c36b5; }
.project-tag-row {
  background-size: 6px 100%;
}
/* Custom hover for rows WITHOUT colors */
.custom-hover-table tbody tr:not(.project-tag-row[data-tag-color]):hover {
  background-color: rgba(0, 0, 0, 0.075);
}
/* Rows WITH colors should ALWAYS show their stripe, never highlight on hover */
.custom-hover-table tbody tr.project-tag-row[data-tag-color] {
  transition: none;
}
.custom-hover-table tbody tr.project-tag-row[data-tag-color]:hover {
  background-color: transparent !important;
}
.custom-hover-table tbody tr.project-tag-row[data-tag-color]:hover td {
  background-color: transparent !important;
}
</style>
