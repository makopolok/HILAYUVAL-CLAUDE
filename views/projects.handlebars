{{!-- views/projects.handlebars --}}
<style>
  .projects-table tbody tr[data-project-id] {
    cursor: context-menu;
    transition: background-color 0.16s ease;
  }

  .project-tag-menu {
    position: absolute;
    z-index: 2100;
    min-width: 170px;
    background: #fff;
    border: 1px solid #ddd;
    border-radius: 8px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.16);
    padding: 6px;
  }

  .project-tag-menu-item {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    border: 0;
    background: transparent;
    text-align: left;
    padding: 7px 8px;
    border-radius: 6px;
    font-size: 14px;
  }

  .project-tag-menu-item:hover {
    background: #f2f4f7;
  }

  .project-tag-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: inline-block;
    flex-shrink: 0;
  }

  .project-tag-dot-none {
    border: 1px solid #adb5bd;
    background: #fff;
  }

  .tag-gray { background: #6c757d; }
  .tag-red { background: #e03131; }
  .tag-orange { background: #f08c00; }
  .tag-yellow { background: #f59f00; }
  .tag-green { background: #2f9e44; }
  .tag-blue { background: #1c7ed6; }
  .tag-purple { background: #9c36b5; }

  .projects-table tbody tr.tag-color-gray { --bs-table-bg: #cfd4da; --bs-table-accent-bg: #cfd4da; }
  .projects-table tbody tr.tag-color-red { --bs-table-bg: #ffb3b3; --bs-table-accent-bg: #ffb3b3; }
  .projects-table tbody tr.tag-color-orange { --bs-table-bg: #ffc078; --bs-table-accent-bg: #ffc078; }
  .projects-table tbody tr.tag-color-yellow { --bs-table-bg: #ffe066; --bs-table-accent-bg: #ffe066; }
  .projects-table tbody tr.tag-color-green { --bs-table-bg: #b2f2bb; --bs-table-accent-bg: #b2f2bb; }
  .projects-table tbody tr.tag-color-blue { --bs-table-bg: #a5d8ff; --bs-table-accent-bg: #a5d8ff; }
  .projects-table tbody tr.tag-color-purple { --bs-table-bg: #d0bfff; --bs-table-accent-bg: #d0bfff; }
  .projects-table tbody tr[class*="tag-color-"] > td { background-color: var(--bs-table-bg) !important; }
  .projects-table tbody tr.tag-color-gray > td:first-child { border-left: 6px solid #6c757d; }
  .projects-table tbody tr.tag-color-red > td:first-child { border-left: 6px solid #e03131; }
  .projects-table tbody tr.tag-color-orange > td:first-child { border-left: 6px solid #f08c00; }
  .projects-table tbody tr.tag-color-yellow > td:first-child { border-left: 6px solid #f59f00; }
  .projects-table tbody tr.tag-color-green > td:first-child { border-left: 6px solid #2f9e44; }
  .projects-table tbody tr.tag-color-blue > td:first-child { border-left: 6px solid #1c7ed6; }
  .projects-table tbody tr.tag-color-purple > td:first-child { border-left: 6px solid #9c36b5; }
</style>

<div class="container mt-5">
  <h1 class="display-4 mb-4">Projects</h1>
  <div class="d-flex flex-wrap gap-2 mb-3">
    <a href="/projects/create" class="btn btn-outline-success">Create New Project</a>
    <a href="/admin/upload-intents" class="btn btn-outline-primary">
      <i class="fa-solid fa-cloud-arrow-up me-1"></i>Upload Intents Monitor
    </a>
    <button type="button" class="btn btn-outline-secondary" data-theme-toggle aria-label="Toggle dark mode" title="Toggle dark mode">
      <i class="fa-solid fa-moon me-1" data-theme-icon></i>Dark Mode
    </button>
  </div>
  <form class="row g-3 mb-4" method="GET" action="">
    <div class="col-md-8 col-lg-6">
      <input type="text" class="form-control" name="term" placeholder="Search by performer or email" value="{{query.term}}">
    </div>
    <div class="col-md-4 col-lg-3 d-flex align-items-center gap-2">
      <button type="submit" class="btn btn-outline-danger">Global Search</button>
    </div>
  </form>
  {{#if searchPerformed}}
  <div class="card mb-4">
    <div class="card-header">Audition Search Results</div>
    <div class="card-body">
      {{#if searchError}}
        <div class="alert alert-danger mb-0">{{searchError}}</div>
      {{else}}
        {{#if searchResults.length}}
          <div class="table-responsive">
            <table class="table table-striped">
              <thead>
                <tr>
                  <th>Performer</th>
                  <th>Email</th>
                  <th>Role</th>
                  <th>Project</th>
                  <th>Submitted</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                {{#each searchResults}}
                <tr>
                  <td>{{this.display_name}}</td>
                  <td>{{this.email}}</td>
                  <td>{{this.role}}</td>
                  <td>{{this.project_name}}</td>
                  <td>{{this.created_at_formatted}}</td>
                  <td>
                    <a href="/projects/{{this.project_id}}/auditions" class="btn btn-outline-primary btn-sm">View Auditions</a>
                  </td>
                </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
        {{else}}
          <p class="mb-0">No auditions matched your search.</p>
        {{/if}}
      {{/if}}
    </div>
  </div>
  {{/if}}
  {{#if projects.length}}
    <table class="table table-bordered custom-hover-table projects-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Auditions</th>
          <th>Created</th>
          <th>Audition Form Link</th>
          <th>Audition Playlist</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each projects}}
        <tr data-project-id="{{this.id}}" class="{{#if this.tag_color}}tag-color-{{this.tag_color}}{{/if}}">
          <td>{{this.name}}</td>
          <td>
            <span class="fw-semibold">{{this.auditionsCount}}</span>
            {{#if this.newAuditionsCount}}
              <span class="badge text-bg-danger ms-2">+{{this.newAuditionsCount}} new</span>
            {{/if}}
          </td>
          <td>{{this.created_at_formatted}}</td>
          <td>
            <a href="/audition/{{this.id}}" target="_blank">/audition/{{this.id}}</a>
          </td>
          <td>
            <a href="/projects/{{this.id}}/auditions" class="btn btn-outline-danger btn-sm">View Auditions</a>
          </td>
          <td>
            <a href="/projects/{{this.id}}/edit" class="btn btn-outline-secondary btn-sm">Edit</a>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  {{else}}
    <p>No projects found.</p>
  {{/if}}

  <div id="project-tag-menu" class="project-tag-menu d-none" role="menu" aria-label="Set row color">
    <button type="button" class="project-tag-menu-item" data-tag-color="">
      <span class="project-tag-dot project-tag-dot-none"></span>
      No color
    </button>
    <button type="button" class="project-tag-menu-item" data-tag-color="gray"><span class="project-tag-dot tag-gray"></span>Gray</button>
    <button type="button" class="project-tag-menu-item" data-tag-color="red"><span class="project-tag-dot tag-red"></span>Red</button>
    <button type="button" class="project-tag-menu-item" data-tag-color="orange"><span class="project-tag-dot tag-orange"></span>Orange</button>
    <button type="button" class="project-tag-menu-item" data-tag-color="yellow"><span class="project-tag-dot tag-yellow"></span>Yellow</button>
    <button type="button" class="project-tag-menu-item" data-tag-color="green"><span class="project-tag-dot tag-green"></span>Green</button>
    <button type="button" class="project-tag-menu-item" data-tag-color="blue"><span class="project-tag-dot tag-blue"></span>Blue</button>
    <button type="button" class="project-tag-menu-item" data-tag-color="purple"><span class="project-tag-dot tag-purple"></span>Purple</button>
  </div>
  
  <hr class="my-4">
  {{! Debug: Show raw deploymentInfo object }}
  {{#if deploymentInfo}}
  <div class="alert alert-warning small mb-2">
    <strong>DEBUG - Raw data:</strong> 
    Commit: {{deploymentInfo.commit}}, Version: {{deploymentInfo.version}}, Branch: {{deploymentInfo.branch}}, Date: {{deploymentInfo.deployDate}}
  </div>
  {{else}}
  <div class="alert alert-danger small mb-2">
    <strong>DEBUG:</strong> deploymentInfo is null/undefined!
  </div>
  {{/if}}
  
  <div class="alert alert-info small mb-3">
    <strong>Version Info:</strong> 
    Commit: {{deploymentInfo.commit}} | 
    Version: {{deploymentInfo.version}} | 
    Branch: {{deploymentInfo.branch}} | 
    Deployed: {{deploymentInfo.deployDate}}
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const menu = document.getElementById('project-tag-menu');
  const rows = document.querySelectorAll('.projects-table tbody tr[data-project-id]');
  if (!menu || rows.length === 0) return;

  const tagClasses = ['gray', 'red', 'orange', 'yellow', 'green', 'blue', 'purple'].map((color) => `tag-color-${color}`);
  const tagColorHex = {
    gray: '#cfd4da',
    red: '#ffb3b3',
    orange: '#ffc078',
    yellow: '#ffe066',
    green: '#b2f2bb',
    blue: '#a5d8ff',
    purple: '#d0bfff'
  };
  let activeRow = null;

  const hideMenu = () => {
    menu.classList.add('d-none');
    activeRow = null;
  };

  const applyRowColor = (row, color) => {
    tagClasses.forEach((className) => row.classList.remove(className));
    if (color) {
      row.classList.add(`tag-color-${color}`);
    }
    const cells = row.querySelectorAll('td');
    const nextColor = tagColorHex[color] || '';
    cells.forEach((cell) => {
      if (nextColor) {
        cell.style.setProperty('--bs-table-bg', nextColor);
        cell.style.setProperty('--bs-table-accent-bg', nextColor);
        cell.style.backgroundColor = nextColor;
        cell.style.boxShadow = `inset 0 0 0 9999px ${nextColor}`;
      } else {
        cell.style.removeProperty('--bs-table-bg');
        cell.style.removeProperty('--bs-table-accent-bg');
        cell.style.removeProperty('background-color');
        cell.style.removeProperty('box-shadow');
      }
    });
  };

  rows.forEach((row) => {
    const match = Array.from(row.classList).find((className) => className.startsWith('tag-color-'));
    if (match) {
      applyRowColor(row, match.replace('tag-color-', ''));
    }
  });

  rows.forEach((row) => {
    row.addEventListener('contextmenu', (event) => {
      event.preventDefault();
      activeRow = row;
      menu.classList.remove('d-none');
      menu.style.left = `${event.pageX}px`;
      menu.style.top = `${event.pageY}px`;
    });
  });

  menu.addEventListener('click', async (event) => {
    const item = event.target.closest('.project-tag-menu-item');
    if (!item || !activeRow) return;

    const selectedRow = activeRow;
    const projectId = selectedRow.dataset.projectId;
    const tagColor = (item.dataset.tagColor || '').trim().toLowerCase();
    hideMenu();
    try {
      const response = await fetch(`/projects/${projectId}/tag-color`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Accept: 'application/json',
          'X-Requested-With': 'fetch'
        },
        credentials: 'same-origin',
        body: JSON.stringify({ tagColor: tagColor || null })
      });
      const payload = await response.json().catch(() => ({}));
      if (!response.ok || !payload.ok) {
        if (response.status === 401) {
          window.location.assign(`/admin/login?returnTo=${encodeURIComponent(window.location.pathname + window.location.search)}`);
          return;
        }
        throw new Error(payload.error || 'Failed to save project color');
      }
      applyRowColor(selectedRow, payload.tagColor || '');
    } catch (error) {
      console.error('[PROJECT_TAG_COLOR_SAVE_ERROR]', error);
      alert('Could not save row color. Please try again.');
    }
  });

  document.addEventListener('click', (event) => {
    if (!menu.contains(event.target)) {
      hideMenu();
    }
  });
  window.addEventListener('scroll', hideMenu, true);
  window.addEventListener('resize', hideMenu);
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      hideMenu();
    }
  });
});
</script>
