{{! views/auditions.handlebars }}
<div class="container mt-5">
  <h1 class="display-4 mb-4">Auditions for {{project.name}}</h1>
  <form class="row g-3 mb-4" method="GET" action="" id="audition-filter-form">
    <div class="col-md-4">
      <input type="text" class="form-control" id="name-filter-input" name="name" placeholder="Filter by actor name" value="{{query.name}}">
    </div>
    <div class="col-md-4">
      <input type="text" class="form-control" id="email-filter-input" name="email" placeholder="Filter by email" value="{{query.email}}">
    </div>
    <div class="col-md-4">
      <select class="form-select" name="role" id="role-filter-select">
        <option value="">All Roles</option>
        {{#each role_options}}
          <option value="{{this.name}}" {{#if (eq ../query.role this.name)}}selected{{/if}}>{{this.name}}</option>
        {{/each}}
      </select>
    </div>
    <div class="col-12">
      <button type="submit" class="visually-hidden" aria-hidden="true" tabindex="-1">Apply filters</button>
    </div>
  </form>
  <div class="d-flex justify-content-end gap-2 mb-3">
    <button type="button" class="btn btn-outline-primary btn-sm" id="view-list-btn">List View</button>
    <button type="button" class="btn btn-outline-secondary btn-sm" id="view-cards-btn">Cards View</button>
  </div>
  <div id="auditions-list-view">
    {{#if visible_roles.length}}
      <div class="card border-danger mb-4">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0 auditions-list-table">
            <thead>
              <tr>
                <th>Profile</th>
                <th>Name</th>
                <th>Role</th>
                <th>Phone</th>
                <th>Age</th>
                <th>Location</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              {{#each visible_roles}}
                {{#each this.auditions}}
                  <tr>
                    <td>
                      {{#if profile_picture_url}}
                        <img src="{{profile_picture_url}}" alt="Profile picture" class="audition-list-avatar">
                      {{else}}
                        <div class="audition-list-avatar audition-list-avatar-placeholder">
                          <i class="fas fa-user"></i>
                        </div>
                      {{/if}}
                    </td>
                    <td>
                      <div class="fw-semibold text-danger">
                        {{#if first_name_he}}{{first_name_he}} {{last_name_he}}{{else}}{{first_name_en}} {{last_name_en}}{{/if}}
                      </div>
                      <small class="text-muted">{{email}}</small>
                    </td>
                    <td>
                      <span class="badge text-bg-light border">{{../name}}</span>
                    </td>
                    <td>{{phone}}</td>
                    <td>{{#if age}}{{age}}{{else}}—{{/if}}</td>
                    <td>{{#if current_location}}{{current_location}}{{else}}—{{/if}}</td>
                    <td>
                      <div class="d-flex gap-2 flex-wrap">
                        {{#if video_url}}
                          <a class="btn btn-outline-danger btn-sm" target="_blank" rel="noopener" href="{{#if video_watch_url}}{{video_watch_url}}{{else if embed_url}}{{embed_url}}{{else}}{{video_url}}{{/if}}">
                            <i class="fas fa-play"></i>
                          </a>
                        {{/if}}
                        {{#if showreel_url}}
                          <a class="btn btn-outline-secondary btn-sm" target="_blank" rel="noopener" href="{{showreel_url}}">
                            <i class="fas fa-film"></i>
                          </a>
                        {{/if}}
                        {{#if about_me}}
                          <button
                            type="button"
                            class="btn btn-outline-secondary btn-sm about-me-popover-btn"
                            data-bs-toggle="popover"
                            data-bs-trigger="focus"
                            data-bs-placement="top"
                            data-bs-title="About"
                            data-bs-content="{{about_me}}">
                            <i class="fas fa-comment-dots"></i>
                          </button>
                        {{/if}}
                      </div>
                    </td>
                  </tr>
                {{/each}}
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>
    {{else}}
      <p>No matching roles found for the selected filter.</p>
    {{/if}}
  </div>
  <div id="auditions-cards-view" class="d-none">
  {{#if visible_roles.length}}
    {{#each visible_roles}}
      <div class="card mb-4 border-danger audition-role-card">
        <div class="card-header bg-danger text-white fw-bold">
          Role: {{this.name}} ({{this.totalAuditions}})
          {{#if this.newAuditionsCount}}
            <span class="ms-2 badge bg-light text-danger">+{{this.newAuditionsCount}} new</span>
          {{/if}}
        </div>
        <div class="card-body">
          {{#if this.auditions}}
            <div class="row">
              {{#each this.auditions}}
                <div class="col-md-6 col-lg-4 mb-4">
                  <div
                    class="card h-100 border-danger audition-video-card audition-tag-card{{#if tag_color}} tag-color-{{tag_color}}{{/if}}"
                    data-audition-id="{{id}}"
                    data-project-id="{{../../project.id}}"
                    data-tag-color="{{tag_color}}">
                    <div class="card-body">
                      <!-- Actor Name and Delete Button -->
                      <div class="d-flex justify-content-between align-items-start mb-2">
                        <h6 class="card-title text-danger mb-0">
                          {{#if first_name_he}}{{first_name_he}} {{last_name_he}}{{/if}}
                          {{#if first_name_en}}
                            {{#if first_name_he}}<br><small class="text-muted">{{/if}}
                            {{first_name_en}} {{last_name_en}}
                            {{#if first_name_he}}</small>{{/if}}
                          {{/if}}
                        </h6>
                        <button type="button" class="btn btn-sm btn-outline-danger border-0 delete-audition-btn" title="Delete Audition" data-audition-id="{{id}}" data-project-id="{{../../project.id}}">
                          <i class="fas fa-trash-alt"></i>
                        </button>
                      </div>
                      
                      <!-- Contact Info -->
                      <p class="card-text small mb-2">
                        <i class="fas fa-envelope me-1"></i>{{email}}
                      </p>
                      {{#if phone}}
                      <p class="card-text small mb-2">
                        <i class="fas fa-phone me-1"></i>{{phone}}
                      </p>
                      {{/if}}

                      {{#if profile_picture_url}}
                      <div class="mb-3 text-center">
                        <a class="btn btn-outline-secondary btn-sm" target="_blank" rel="noopener" href="{{profile_picture_url}}">
                          <i class="fas fa-user-circle me-2"></i>Profile Picture
                        </a>
                      </div>
                      {{/if}}
                      <div class="mb-3 d-flex justify-content-center gap-2 audition-card-links-row">
                        {{#if showreel_url}}
                          <a class="btn btn-outline-secondary btn-sm" target="_blank" rel="noopener" href="{{showreel_url}}">
                            <i class="fas fa-film me-2"></i>Showreel
                          </a>
                        {{/if}}
                        {{#if about_me}}
                          <button
                            type="button"
                            class="btn btn-outline-secondary btn-sm about-me-popover-btn"
                            data-bs-toggle="popover"
                            data-bs-trigger="focus"
                            data-bs-placement="top"
                            data-bs-title="About"
                            data-bs-content="{{about_me}}">
                            <i class="fas fa-comment-dots me-2"></i>About
                          </button>
                        {{/if}}
                      </div>
                       
                      <!-- Video Player -->
                      {{#if video_url}}
                        {{#if (eq video_type "youtube")}}
                        <div class="mb-3 youtube-video">
                          <div class="ratio ratio-16x9">
                            <iframe
                              src="{{#if embed_url}}{{embed_url}}{{else}}https://www.youtube.com/embed/{{video_url}}{{/if}}"
                              title="YouTube audition video"
                              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                              allowfullscreen
                              class="rounded">
                            </iframe>
                          </div>
                          <div class="mt-2 text-center">
                            <a class="btn btn-outline-primary btn-sm" target="_blank" rel="noopener" href="{{#if video_watch_url}}{{video_watch_url}}{{else}}{{video_url}}{{/if}}">
                              <i class="fab fa-youtube me-2"></i>YouTube
                            </a>
                          </div>
                        </div>
                        {{else if (and (eq video_type "bunny_stream") video_url (isLength video_url min=10))}}
                        <!-- Bunny.net Stream Video -->
                        {{#if ../../disable_inline_player}}
                          <div class="text-center p-3 mb-3" style="background-color: #f8f9fa; border-radius: 8px;">
                   <a class="btn btn-outline-primary btn-sm" target="_blank" rel="noopener"
                     href="{{#if embed_url}}{{embed_url}}{{else}}https://iframe.mediadelivery.net/embed/{{../../bunny_stream_library_id}}/{{video_url}}?autoplay=false{{/if}}">
                              <i class="fas fa-external-link-alt me-2"></i>Open Video
                            </a>
                            <div class="small text-muted mt-2">Inline player disabled</div>
                          </div>
                        {{else}}
                        <div class="video-container mb-3" data-video-url="{{video_url}}" data-video-type="{{video_type}}" data-library-id="{{../../bunny_stream_library_id}}">
                          <div class="video-loading text-center p-3" style="background-color: #f8f9fa; border-radius: 8px;">
                            <div class="spinner-border spinner-border-sm text-danger mb-2" role="status">
                              <span class="visually-hidden">Loading...</span>
                            </div>
                            <div class="small text-muted">Loading video...</div>
                          </div>
                          <div class="video-player" style="display: none;">
                            <div class="ratio ratio-16x9">
                              <iframe 
                                src="{{#if embed_url}}{{embed_url}}{{else}}https://iframe.mediadelivery.net/embed/{{../../bunny_stream_library_id}}/{{video_url}}?autoplay=false{{/if}}" 
                                frameborder="0" 
                                allowfullscreen
                                allow="accelerometer; gyroscope; encrypted-media; picture-in-picture;"
                                class="rounded">
                              </iframe>
                            </div>
                          </div>
                          <div class="video-error text-center p-3" style="display: none; background-color: #f8d7da; border-radius: 8px;">
                            <div class="small text-danger">
                              <i class="fas fa-exclamation-triangle me-1"></i>
                              Video processing in progress. <a href="javascript:void(0)" onclick="retryVideo(this)">Retry</a>
                            </div>
                          </div>
                        </div>
                        {{/if}}
                        {{#if youtube_video_url}}
                        <div class="alert alert-info small py-2 mb-3" role="alert">
                          <i class="fab fa-youtube me-1"></i>
                          Also available on YouTube: <a href="{{youtube_video_url}}" target="_blank" rel="noopener">open</a>
                        </div>
                        {{else if ../../youtube_ready}}
                        <form method="POST" action="/projects/{{../../project.id}}/auditions/{{id}}/upload-to-youtube" class="mt-2">
                          <input type="hidden" name="redirect" value="{{../../redirect_to}}">
                          <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                            <i class="fab fa-youtube me-1"></i>Upload to YouTube
                          </button>
                        </form>
                        {{/if}}
                        {{else}}
                        <div class="text-center p-3 mb-3" style="background-color: #f8f9fa; border-radius: 8px;">
                          <i class="fas fa-video-slash text-muted mb-2"></i>
                          <div class="small text-danger">No valid Bunny.net video ID found. Please check the submission or contact support.</div>
                        </div>
                        {{/if}}
                      {{else}}
                      <!-- No Video -->
                      <div class="text-center p-3 mb-3" style="background-color: #f8f9fa; border-radius: 8px;">
                        <i class="fas fa-video-slash text-muted mb-2"></i>
                        <div class="small text-muted">No video submitted</div>
                      </div>
                      {{/if}}
                      
                      <!-- Additional Info -->
                      {{#if agency}}
                      <p class="card-text small mb-1">
                        <strong>Agency:</strong> {{agency}}
                      </p>
                      {{/if}}
                      {{#if age}}
                      <p class="card-text small mb-1">
                        <strong>Age:</strong> {{age}}
                      </p>
                      {{/if}}
                      {{#if height}}
                      <p class="card-text small mb-1">
                        <strong>Height:</strong> {{height}}cm
                      </p>
                      {{/if}}
                      {{#if current_location}}
                      <p class="card-text small mb-1">
                        <strong>Based in:</strong> {{current_location}}
                      </p>
                      {{/if}}
                      {{#if about_me}}
                      <p class="card-text small mb-1">
                        <strong>About:</strong> {{about_me}}
                      </p>
                      {{/if}}
                      
                      <p class="card-text"><small class="text-muted">Submitted: {{created_at_formatted}}</small></p>
                    </div>
                  </div>
                </div>
              {{/each}}
            </div>
          {{else}}
            <p class="text-muted">No auditions submitted for this role yet.</p>
          {{/if}}
        </div>
      </div>
    {{/each}}
  {{else}}
    <p>No matching roles found for the selected filter.</p>
  {{/if}}
  </div>

  <a href="/projects" class="btn btn-outline-danger mt-4">Back to Projects</a>
</div>

<div id="audition-tag-menu" class="audition-tag-menu d-none" role="menu" aria-label="Set row color">
  <button type="button" class="audition-tag-menu-item" data-tag-color="">
    <span class="audition-tag-dot audition-tag-dot-none"></span>
    No color
  </button>
  <button type="button" class="audition-tag-menu-item" data-tag-color="gray"><span class="audition-tag-dot tag-gray"></span>Gray</button>
  <button type="button" class="audition-tag-menu-item" data-tag-color="red"><span class="audition-tag-dot tag-red"></span>Red</button>
  <button type="button" class="audition-tag-menu-item" data-tag-color="orange"><span class="audition-tag-dot tag-orange"></span>Orange</button>
  <button type="button" class="audition-tag-menu-item" data-tag-color="yellow"><span class="audition-tag-dot tag-yellow"></span>Yellow</button>
  <button type="button" class="audition-tag-menu-item" data-tag-color="green"><span class="audition-tag-dot tag-green"></span>Green</button>
  <button type="button" class="audition-tag-menu-item" data-tag-color="blue"><span class="audition-tag-dot tag-blue"></span>Blue</button>
  <button type="button" class="audition-tag-menu-item" data-tag-color="purple"><span class="audition-tag-dot tag-purple"></span>Purple</button>
</div>

<!-- Video Player Enhancement Script -->
<script>
function retryVideo(element) {
  const container = element.closest('.video-container');
  const videoUrl = container.dataset.videoUrl;
  const videoType = container.dataset.videoType;
  const loading = container.querySelector('.video-loading');
  const player = container.querySelector('.video-player');
  const error = container.querySelector('.video-error');
  
  // Show loading, hide error
  loading.style.display = 'block';
  error.style.display = 'none';
  player.style.display = 'none';
  
  // Try to load the video again
  loadVideo(container);
}

function loadVideo(container) {
  const videoUrl = container.dataset.videoUrl;
  const videoType = container.dataset.videoType;
  const loading = container.querySelector('.video-loading');
  const player = container.querySelector('.video-player');
  const error = container.querySelector('.video-error');
  
  // Only try to load Bunny.net Stream videos (YouTube and others load immediately)
  if (videoType === 'bunny_stream') {
    // Use iframe method to check if video is ready
    testIframeLoad(container);
  } else {
    // For YouTube and other types, show immediately
    loading.style.display = 'none';
    player.style.display = 'block';
  }
}

function testIframeLoad(container) {
  const videoUrl = container.dataset.videoUrl;
  const libraryId = container.dataset.libraryId;
  const loading = container.querySelector('.video-loading');
  const player = container.querySelector('.video-player');
  const error = container.querySelector('.video-error');
  
  // Create a test iframe to check if video is ready
  const testIframe = document.createElement('iframe');
  testIframe.style.display = 'none';
  testIframe.style.position = 'absolute';
  testIframe.style.left = '-9999px';
  testIframe.src = `https://iframe.mediadelivery.net/embed/${libraryId}/${videoUrl}?autoplay=false`;
  
  let loadTimeout = setTimeout(() => {
    // If iframe doesn't load within 10 seconds, show error
    try {
      document.body.removeChild(testIframe);
    } catch(e) {
      // Iframe already removed
    }
    
    loading.style.display = 'none';
    error.style.display = 'block';
  }, 10000);
  
  testIframe.onload = function() {
    clearTimeout(loadTimeout);
    // Video appears to be ready
    loading.style.display = 'none';
    player.style.display = 'block';
    
    // Remove test iframe
    try {
      document.body.removeChild(testIframe);
    } catch(e) {
      // Iframe already removed
    }
  };
  
  testIframe.onerror = function() {
    clearTimeout(loadTimeout);
    // Video not ready yet
    try {
      document.body.removeChild(testIframe);
    } catch(e) {
      // Iframe already removed
    }
    
    loading.style.display = 'none';
    error.style.display = 'block';
  };
  
  document.body.appendChild(testIframe);
}

const TAG_COLOR_CLASSES = ['gray', 'red', 'orange', 'yellow', 'green', 'blue', 'purple'].map((color) => `tag-color-${color}`);

function clearTagColorClasses(card) {
  TAG_COLOR_CLASSES.forEach((className) => card.classList.remove(className));
}

function applyTagColor(card, color) {
  clearTagColorClasses(card);
  const normalized = (color || '').toString().trim().toLowerCase();
  if (normalized) {
    card.classList.add(`tag-color-${normalized}`);
  }
  card.dataset.tagColor = normalized;
}

function hideTagMenu() {
  const menu = document.getElementById('audition-tag-menu');
  if (!menu) return;
  menu.classList.add('d-none');
  delete menu.dataset.auditionId;
}

function showTagMenu(event, card) {
  const menu = document.getElementById('audition-tag-menu');
  if (!menu) return;
  menu.classList.remove('d-none');
  menu.style.left = `${event.pageX}px`;
  menu.style.top = `${event.pageY}px`;
  menu.dataset.auditionId = card.dataset.auditionId;
}

async function saveTagColor(card, tagColor) {
  const projectId = card.dataset.projectId;
  const auditionId = card.dataset.auditionId;
  if (!projectId || !auditionId) return;

  const response = await fetch(`/projects/${projectId}/auditions/${auditionId}/tag-color`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ tagColor: tagColor || null })
  });
  const payload = await response.json().catch(() => ({}));
  if (!response.ok || !payload.ok) {
    throw new Error(payload.error || 'Failed to save color');
  }
  applyTagColor(card, payload.tagColor || '');
}

// Load all videos when page loads
document.addEventListener('DOMContentLoaded', function() {
  // Delete Audition Button Logic
  document.querySelectorAll('.delete-audition-btn').forEach(btn => {
    btn.addEventListener('click', async function() {
      if (!confirm('Are you sure you want to delete this audition? This action is permanent and will attempt to remove the video from YouTube or Bunny.net as well.')) {
        return;
      }
      
      const projectId = this.dataset.projectId;
      const auditionId = this.dataset.auditionId;
      const btnElement = this;
      const cardContainer = btnElement.closest('.col-md-6, .col-lg-4'); // The wrapper col

      const originalHtml = btnElement.innerHTML;
      btnElement.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>';
      btnElement.disabled = true;

      try {
        const res = await fetch(`/projects/${projectId}/auditions/${auditionId}/delete`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });
        const data = await res.json();
        
        if (data.ok) {
          // Remove the card with a fade out effect
          if (cardContainer) {
            cardContainer.style.transition = 'opacity 0.3s ease';
            cardContainer.style.opacity = '0';
            setTimeout(() => cardContainer.remove(), 300);
          }
        } else {
          alert('Error deleting audition: ' + (data.error || 'Unknown error'));
          btnElement.innerHTML = originalHtml;
          btnElement.disabled = false;
        }
      } catch (err) {
        console.error('Delete error:', err);
        alert('Network error while deleting the audition.');
        btnElement.innerHTML = originalHtml;
        btnElement.disabled = false;
      }
    });
  });

  const roleSelect = document.getElementById('role-filter-select');
  const filterForm = document.getElementById('audition-filter-form');
  const nameFilterInput = document.getElementById('name-filter-input');
  const emailFilterInput = document.getElementById('email-filter-input');
  const listView = document.getElementById('auditions-list-view');
  const cardsView = document.getElementById('auditions-cards-view');
  const listBtn = document.getElementById('view-list-btn');
  const cardsBtn = document.getElementById('view-cards-btn');
  let cardVideosInitialized = false;

  const initCardVideos = () => {
    if (cardVideosInitialized) return;
    const videoContainers = cardsView ? cardsView.querySelectorAll('.video-container') : [];
    videoContainers.forEach((container, index) => {
      setTimeout(() => {
        loadVideo(container);
      }, index * 1000);
    });
    cardVideosInitialized = true;
  };

  const setViewMode = (mode) => {
    const showCards = mode === 'cards';
    if (listView) listView.classList.toggle('d-none', showCards);
    if (cardsView) cardsView.classList.toggle('d-none', !showCards);
    if (listBtn) {
      listBtn.classList.toggle('btn-primary', !showCards);
      listBtn.classList.toggle('btn-outline-primary', showCards);
    }
    if (cardsBtn) {
      cardsBtn.classList.toggle('btn-primary', showCards);
      cardsBtn.classList.toggle('btn-outline-secondary', !showCards);
    }
    if (showCards) {
      initCardVideos();
    }
    try {
      localStorage.setItem('auditionsViewMode', mode);
    } catch (_) {}
  };

  if (listBtn) {
    listBtn.addEventListener('click', () => setViewMode('list'));
  }
  if (cardsBtn) {
    cardsBtn.addEventListener('click', () => setViewMode('cards'));
  }

  const savedMode = (() => {
    try {
      return localStorage.getItem('auditionsViewMode');
    } catch (_) {
      return null;
    }
  })();
  setViewMode(savedMode === 'cards' ? 'cards' : 'list');

  if (roleSelect && filterForm) {
    roleSelect.addEventListener('change', function () {
      filterForm.submit();
    });
  }
  const submitOnEnter = function (event) {
    if (event.key !== 'Enter' || !filterForm) return;
    event.preventDefault();
    filterForm.submit();
  };
  if (nameFilterInput) nameFilterInput.addEventListener('keydown', submitOnEnter);
  if (emailFilterInput) emailFilterInput.addEventListener('keydown', submitOnEnter);

  if (window.bootstrap && window.bootstrap.Popover) {
    document.querySelectorAll('.about-me-popover-btn').forEach((button) => {
      new window.bootstrap.Popover(button, {
        container: 'body',
        html: false,
      });
    });
  }

  let activeTagCard = null;
  const tagMenu = document.getElementById('audition-tag-menu');
  const tagCards = document.querySelectorAll('.audition-tag-card');
  if (tagMenu && tagCards.length) {
    tagCards.forEach((card) => {
      card.addEventListener('contextmenu', (event) => {
        event.preventDefault();
        activeTagCard = card;
        showTagMenu(event, card);
      });
    });

    tagMenu.addEventListener('click', async (event) => {
      const item = event.target.closest('.audition-tag-menu-item');
      if (!item || !activeTagCard) return;
      const newColor = (item.dataset.tagColor || '').trim().toLowerCase();
      tagMenu.classList.add('d-none');
      try {
        await saveTagColor(activeTagCard, newColor);
      } catch (error) {
        console.error('[AUDITION_TAG_COLOR_SAVE_ERROR]', error);
        alert('Could not save row color. Please try again.');
      } finally {
        activeTagCard = null;
      }
    });

    document.addEventListener('click', (event) => {
      if (!tagMenu.contains(event.target)) {
        hideTagMenu();
      }
    });

    window.addEventListener('scroll', hideTagMenu, true);
    window.addEventListener('resize', hideTagMenu);
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        hideTagMenu();
      }
    });
  }
});
</script>

<style>
.audition-tag-menu {
  position: absolute;
  z-index: 2000;
  min-width: 170px;
  background: #fff;
