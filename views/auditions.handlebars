{{! views/auditions.handlebars }}
<style>
  /* Paint a stable white surface immediately to prevent visual bleed/flicker on first render */
  body {
    background: #ffffff !important;
    background-image: none !important;
  }
  #auditions-list-view,
  #auditions-list-view .card,
  #auditions-list-view .table-responsive,
  #auditions-list-view .auditions-list-table,
  #auditions-list-view .auditions-list-table thead,
  #auditions-list-view .auditions-list-table tbody,
  #auditions-list-view .auditions-list-table tr,
  #auditions-list-view .auditions-list-table td,
  #auditions-list-view .auditions-list-table th {
    background: #ffffff !important;
    background-image: none !important;
  }
  #auditions-list-view {
    isolation: isolate;
  }
  .auditions-page {
    --audition-red: rgb(190, 26, 26);
    --audition-header-red: rgb(219, 26, 26);
  }
  .auditions-page .display-4 {
    color: var(--audition-header-red) !important;
  }
  .auditions-page .auditions-header {
    display: flex;
    /* align title and counters on the same baseline */
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .auditions-page .auditions-header-title {
    margin: 0;
    /* use the large display style from the heading so children can inherit */
    font-size: inherit;
  }
  .auditions-page .auditions-header-counters {
    display: inline-flex;
    /* match the title font size exactly and inherit font family/weight */
    align-items: baseline;
    gap: 0.6rem;
    font-size: inherit;
    font-weight: inherit;
    font-family: inherit;
    line-height: 1;
  }
  .auditions-page .auditions-list-table .fw-semibold.text-danger,
  .auditions-page .audition-video-card .card-title.text-danger {
    color: var(--audition-red) !important;
  }
  .auditions-page .auditions-total-count {
    color: rgb(208, 49, 30) !important;
    /* inherit title size so characters match exactly */
    font-size: inherit;
    font-weight: inherit;
    font-family: inherit;
    line-height: 1;
    margin-top: 0;
  }
  .auditions-page .auditions-new-count-badge {
    background-color: var(--audition-red);
    color: #fff;
    border-radius: 0.35rem;
    padding: 0.2rem 0.6rem;
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.1;
  }
  .auditions-page .audition-role-card.border-danger,
  .auditions-page .audition-video-card.border-danger,
  .auditions-page #auditions-list-view .card.border-danger {
    border-color: var(--audition-red) !important;
  }
  .auditions-page .audition-role-card .card-header.bg-danger,
  .auditions-page .badge.text-bg-danger {
    background-color: var(--audition-red) !important;
    border-color: var(--audition-red) !important;
  }
  .auditions-page .btn-outline-danger,
  .auditions-page .delete-audition-btn {
    color: var(--audition-red) !important;
    border-color: var(--audition-red) !important;
  }
  .auditions-page .btn-outline-danger:hover,
  .auditions-page .btn-outline-danger:focus {
    background-color: var(--audition-red) !important;
    color: #fff !important;
  }
  .auditions-page .card.border-danger::before {
    content: none !important;
    display: none !important;
  }
  .auditions-page .card.border-danger,
  .auditions-page .table,
  .auditions-page .table-responsive {
    background: #ffffff !important;
    background-image: none !important;
  }
  .auditions-page #auditions-list-view .card.border-danger {
    contain: paint;
  }
  .auditions-page .auditions-role-accordion {
    --bs-accordion-border-color: var(--audition-red);
    --bs-accordion-btn-focus-border-color: var(--audition-red);
    --bs-accordion-btn-focus-box-shadow: 0 0 0 0.2rem rgba(190, 26, 26, 0.15);
  }
  .auditions-page .auditions-role-accordion .accordion-item {
    border-color: var(--audition-red);
  }
  .auditions-page .auditions-role-accordion .accordion-button {
    color: var(--audition-red);
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .auditions-page .auditions-role-accordion .accordion-button:not(.collapsed) {
    color: #fff;
    background-color: var(--audition-red);
    box-shadow: none;
  }
  .auditions-page .auditions-role-accordion .accordion-button::after {
    filter: grayscale(1) brightness(0.6);
  }
  .auditions-page .auditions-role-accordion .accordion-button:not(.collapsed)::after {
    filter: brightness(0) invert(1);
  }
  .auditions-page .auditions-role-label {
    flex: 1 1 auto;
    min-width: 0;
  }
  .auditions-page .auditions-role-count {
    flex: 0 0 auto;
    min-width: 3rem;
    text-align: center;
  }
</style>
<div class="container mt-5 auditions-page">
  <h1 class="display-4 mb-4 auditions-header">
    <span class="auditions-header-title">Auditions for {{project.name}}</span>
    <span class="display-4 auditions-header-counters">
      <span class="auditions-total-count">{{project_auditions_count}}</span>
      {{#if project_new_auditions_count}}
        <span class="auditions-new-count-badge">+{{project_new_auditions_count}} new</span>
      {{/if}}
    </span>
  </h1>
  <form class="row g-3 mb-4" method="GET" action="" id="audition-filter-form">
    <div class="col-md-4">
      <input type="text" class="form-control" id="name-filter-input" name="name" placeholder="Filter by actor name" value="{{query.name}}">
    </div>
    <div class="col-md-4">
      <input type="text" class="form-control" id="email-filter-input" name="email" placeholder="Filter by email" value="{{query.email}}">
    </div>
    <div class="col-md-4">
      <select class="form-select" name="role" id="role-filter-select">
        <option value="">All Roles</option>
        {{#each role_options}}
          <option value="{{this.name}}" {{#if (eq ../query.role this.name)}}selected{{/if}}>{{this.name}}</option>
        {{/each}}
      </select>
    </div>
    <div class="col-12">
      <button type="submit" class="visually-hidden" aria-hidden="true" tabindex="-1">Apply filters</button>
    </div>
  </form>
  <div class="d-flex justify-content-end gap-2 mb-3">
    <button type="button" class="btn btn-outline-primary btn-sm" id="view-list-btn">List View</button>
    <button type="button" class="btn btn-outline-secondary btn-sm" id="view-cards-btn">Cards View</button>
  </div>
  <div id="auditions-list-view">
    {{#if visible_roles.length}}
      <div class="accordion auditions-role-accordion mb-4" id="auditions-role-accordion">
        {{#each visible_roles}}
          <div class="accordion-item">
            <h2 class="accordion-header" id="role-heading-{{this.id}}">
              <button
                class="accordion-button collapsed"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#role-collapse-{{this.id}}"
                aria-expanded="false"
                aria-controls="role-collapse-{{this.id}}">
                <span class="auditions-role-label">{{this.name}}</span>
                <span class="badge text-bg-light border auditions-role-count">{{this.auditions.length}}</span>
                {{#if this.newAuditionsCount}}
                  <span class="auditions-new-count-badge ms-2">+{{this.newAuditionsCount}} new</span>
                {{/if}}
              </button>
            </h2>
            <div
              id="role-collapse-{{this.id}}"
              class="accordion-collapse collapse"
              aria-labelledby="role-heading-{{this.id}}"
              data-bs-parent="#auditions-role-accordion">
              <div class="accordion-body p-0">
                <div class="table-responsive">
                  <table class="table table-hover align-middle mb-0 auditions-list-table">
                    <thead>
                      <tr>
                        <th>Profile</th>
                        <th>Name</th>
                        <th>Role</th>
                        <th>Phone</th>
                        <th>Agency</th>
                        <th>Age</th>
                        <th>Location</th>
                        <th>Actions</th>
                      </tr>
                    </thead>
                    <tbody>
                      {{#each this.auditions}}
                  <tr id="audition-row-{{id}}" class="audition-row{{#if tag_color}} tag-color-{{tag_color}}{{/if}}" data-audition-id="{{id}}" data-project-id="{{../../project.id}}" data-tag-color="{{tag_color}}">
                    <td>
                      {{#if profile_picture_url}}
                        <div class="audition-list-avatar-wrapper">
                          <img
                            src="{{profile_picture_url}}"
                            alt="Profile picture"
                            class="audition-list-avatar"
                            width="54"
                            height="54"
                            loading="lazy"
                            onerror="this.classList.add('d-none'); if (this.nextElementSibling) this.nextElementSibling.classList.remove('d-none');">
                          <div class="audition-list-avatar audition-list-avatar-missing d-none" aria-hidden="true"></div>
                        </div>
                      {{else}}
                        <div class="audition-list-avatar audition-list-avatar-placeholder">
                          <i class="fas fa-user"></i>
                        </div>
                      {{/if}}
                    </td>
                    <td>
                      <div class="fw-semibold text-danger edit-field">
                        <span class="edit-display">
                          {{#if first_name_he}}{{first_name_he}} {{last_name_he}}{{else}}{{first_name_en}} {{last_name_en}}{{/if}}
                        </span>
                        <div class="edit-input d-none">
                          <input type="text" class="form-control form-control-sm mb-1" placeholder="First Name (EN)" data-field="first_name_en" value="{{first_name_en}}">
                          <input type="text" class="form-control form-control-sm mb-1" placeholder="Last Name (EN)" data-field="last_name_en" value="{{last_name_en}}">
                          <input type="text" class="form-control form-control-sm mb-1" placeholder="First Name (HE)" data-field="first_name_he" value="{{first_name_he}}">
                          <input type="text" class="form-control form-control-sm" placeholder="Last Name (HE)" data-field="last_name_he" value="{{last_name_he}}">
                        </div>
                      </div>
                      <small class="text-muted edit-field">
                        <span class="edit-display">{{email}}</span>
                        <input type="email" class="form-control form-control-sm d-none edit-input" placeholder="Email" data-field="email" value="{{email}}">
                      </small>
                    </td>
                    <td>
                      <span class="badge text-bg-light border">{{../name}}</span>
                    </td>
                    <td class="edit-field">
                      <span class="edit-display">{{phone}}</span>
                      <input type="tel" class="form-control form-control-sm d-none edit-input" placeholder="Phone" data-field="phone" value="{{phone}}">
                    </td>
                    <td class="edit-field">
                      <span class="edit-display">{{#if agency}}{{agency}}{{else}}—{{/if}}</span>
                      <input type="text" class="form-control form-control-sm d-none edit-input" placeholder="Agency" data-field="agency" value="{{agency}}">
                    </td>
                    <td class="edit-field">
                      <span class="edit-display">{{#if age}}{{age}}{{else}}—{{/if}}</span>
                      <input type="number" class="form-control form-control-sm d-none edit-input" placeholder="Age" data-field="age" value="{{age}}">
                    </td>
                    <td class="edit-field">
                      <span class="edit-display">{{#if current_location}}{{current_location}}{{else}}—{{/if}}</span>
                      <textarea class="form-control form-control-sm d-none edit-input" placeholder="Location" data-field="current_location" rows="2">{{current_location}}</textarea>
                      <textarea class="form-control form-control-sm d-none edit-input mt-1" placeholder="About me" data-field="about_me" rows="3">{{about_me}}</textarea>
                    </td>
                    <td>
                      <div class="d-flex gap-2 flex-wrap audition-actions">
                        <div class="action-buttons">
                          {{#if video_url}}
                            <a class="btn btn-outline-danger btn-sm" target="_blank" rel="noopener" href="{{#if youtube_video_url}}{{youtube_video_url}}{{else if video_watch_url}}{{video_watch_url}}{{else if embed_url}}{{embed_url}}{{else}}{{video_url}}{{/if}}">
                              <i class="fas fa-play"></i>
                            </a>
                          {{/if}}
                          {{#if showreel_url}}
                            <a class="btn btn-outline-secondary btn-sm" target="_blank" rel="noopener" href="{{showreel_url}}">
                              <i class="fas fa-film"></i>
                            </a>
                          {{/if}}
                          {{#if about_me}}
                            <button
                              type="button"
                              class="btn btn-outline-secondary btn-sm about-me-popover-btn"
                              data-bs-toggle="popover"
                              data-bs-trigger="focus"
                              data-bs-placement="top"
                              data-bs-title="About"
                              data-bs-content="{{about_me}}">
                              <i class="fas fa-comment-dots"></i>
                            </button>
                          {{/if}}
                          <button type="button" class="btn btn-outline-primary btn-sm edit-audition-btn" title="Edit Audition">
                            <i class="fas fa-edit"></i>
                          </button>
                        </div>
                        <div class="edit-buttons d-none">
                          <button type="button" class="btn btn-success btn-sm save-audition-btn" title="Save Changes">
                            <i class="fas fa-check"></i>
                          </button>
                          <button type="button" class="btn btn-secondary btn-sm cancel-audition-btn" title="Cancel">
                            <i class="fas fa-times"></i>
                          </button>
                        </div>
                      </div>
                    </td>
                  </tr>
                      {{/each}}
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>
        {{/each}}
      </div>
    {{else}}
      <p>No matching roles found for the selected filter.</p>
    {{/if}}
  </div>
  <div id="auditions-cards-view" class="d-none">
  {{#if visible_roles.length}}
    <div class="accordion auditions-role-accordion mb-4" id="auditions-cards-role-accordion">
      {{#each visible_roles}}
        <div class="accordion-item">
          <h2 class="accordion-header" id="cards-role-heading-{{this.id}}">
            <button
              class="accordion-button collapsed"
              type="button"
              data-bs-toggle="collapse"
              data-bs-target="#cards-role-collapse-{{this.id}}"
              aria-expanded="false"
              aria-controls="cards-role-collapse-{{this.id}}">
              <span class="auditions-role-label">{{this.name}}</span>
              <span class="badge text-bg-light border auditions-role-count">{{this.totalAuditions}}</span>
              {{#if this.newAuditionsCount}}
                <span class="auditions-new-count-badge ms-2">+{{this.newAuditionsCount}} new</span>
              {{/if}}
            </button>
          </h2>
          <div
            id="cards-role-collapse-{{this.id}}"
            class="accordion-collapse collapse"
            aria-labelledby="cards-role-heading-{{this.id}}"
            data-bs-parent="#auditions-cards-role-accordion">
            <div class="accordion-body">
              {{#if this.auditions}}
                <div class="row">
                  {{#each this.auditions}}
                <div class="col-md-6 col-lg-4 mb-4">
                  <div
                    class="card h-100 border-danger audition-video-card audition-tag-card{{#if tag_color}} tag-color-{{tag_color}}{{/if}}"
                    data-audition-id="{{id}}"
                    data-project-id="{{../../project.id}}"
                    data-tag-color="{{tag_color}}">
                    <div class="card-body audition-card-body" data-audition-id="{{id}}" data-project-id="{{../../project.id}}">
                      <!-- Actor Name and Delete Button -->
                      <div class="d-flex justify-content-between align-items-start mb-2">
                        <div class="flex-grow-1">
                          <h6 class="card-title text-danger mb-0 edit-field">
                            <span class="edit-display">
                              {{#if first_name_he}}{{first_name_he}} {{last_name_he}}{{/if}}
                              {{#if first_name_en}}
                                {{#if first_name_he}}<br><small class="text-muted">{{/if}}
                                {{first_name_en}} {{last_name_en}}
                                {{#if first_name_he}}</small>{{/if}}
                              {{/if}}
                            </span>
                            <div class="edit-input d-none">
                              <input type="text" class="form-control form-control-sm mb-1" placeholder="First Name (EN)" data-field="first_name_en" value="{{first_name_en}}">
                              <input type="text" class="form-control form-control-sm mb-1" placeholder="Last Name (EN)" data-field="last_name_en" value="{{last_name_en}}">
                              <input type="text" class="form-control form-control-sm mb-1" placeholder="First Name (HE)" data-field="first_name_he" value="{{first_name_he}}">
                              <input type="text" class="form-control form-control-sm" placeholder="Last Name (HE)" data-field="last_name_he" value="{{last_name_he}}">
                            </div>
                          </h6>
                        </div>
                        <div class="d-flex gap-1">
                          <button type="button" class="btn btn-sm btn-outline-primary border-0 edit-audition-btn card-edit-btn" title="Edit Audition">
                            <i class="fas fa-edit"></i>
                          </button>
                          <button type="button" class="btn btn-sm btn-outline-danger border-0 delete-audition-btn" title="Delete Audition" data-audition-id="{{id}}" data-project-id="{{../../project.id}}">
                            <i class="fas fa-trash-alt"></i>
                          </button>
                        </div>
                      </div>
                      
                      <!-- Contact Info -->
                      <p class="card-text small mb-2 edit-field">
                        <i class="fas fa-envelope me-1"></i><span class="edit-display">{{email}}</span>
                        <input type="email" class="form-control form-control-sm d-none edit-input" placeholder="Email" data-field="email" value="{{email}}" style="margin-top: 0.5rem;">
                      </p>
                      {{#if phone}}
                      <p class="card-text small mb-2 edit-field">
                        <i class="fas fa-phone me-1"></i><span class="edit-display">{{phone}}</span>
                        <input type="tel" class="form-control form-control-sm d-none edit-input" placeholder="Phone" data-field="phone" value="{{phone}}" style="margin-top: 0.5rem;">
                      </p>
                      {{/if}}
                      <p class="card-text small mb-2 audition-agency-line edit-field{{#unless agency}} is-empty{{/unless}}">
                        <i class="fas fa-building me-1"></i><span class="audition-agency-value edit-display">{{agency}}</span>
                        <input type="text" class="form-control form-control-sm d-none edit-input" placeholder="Agency" data-field="agency" value="{{agency}}" style="margin-top: 0.5rem;">
                      </p>

                      <div class="mb-3 d-flex justify-content-center gap-2 audition-card-links-row">
                        {{#if profile_picture_url}}
                          <a class="btn btn-outline-secondary btn-sm" target="_blank" rel="noopener" href="{{profile_picture_url}}">
                            <i class="fas fa-user-circle me-1"></i>Profile
                          </a>
                        {{/if}}
                        {{#if showreel_url}}
                          <a class="btn btn-outline-secondary btn-sm" target="_blank" rel="noopener" href="{{showreel_url}}">
                            <i class="fas fa-film me-1"></i>Showreel
                          </a>
                        {{/if}}
                        {{#if about_me}}
                          <button
                            type="button"
                            class="btn btn-outline-secondary btn-sm about-me-popover-btn"
                            data-bs-toggle="popover"
                            data-bs-trigger="focus"
                            data-bs-placement="top"
                            data-bs-title="About"
                            data-bs-content="{{about_me}}">
                           <i class="fas fa-comment-dots me-1"></i>About
                          </button>
                        {{/if}}
                      </div>
                       
                      <!-- Video Player -->
                      {{#if video_url}}
                        {{#if (eq video_type "youtube")}}
                        <div class="mb-3 youtube-video">
                          <div class="ratio ratio-16x9">
                            <iframe
                              data-src="{{#if embed_url}}{{embed_url}}{{else}}https://www.youtube.com/embed/{{youtubeVideoId video_url}}{{/if}}"
                              title="YouTube audition video"
                              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                              allowfullscreen
                              loading="lazy"
                              class="rounded">
                            </iframe>
                          </div>
                          <div class="mt-2 text-center">
                            <a class="btn btn-outline-primary btn-sm" target="_blank" rel="noopener" href="{{#if video_watch_url}}{{video_watch_url}}{{else}}{{video_url}}{{/if}}">
                              <i class="fab fa-youtube me-2"></i>YouTube
                            </a>
                          </div>
                        </div>
                        {{else if (and (eq video_type "bunny_stream") video_url (isLength video_url min=10))}}
                        <!-- Bunny.net Stream Video -->
                        {{#if ../../disable_inline_player}}
                          <div class="text-center p-3 mb-3" style="background-color: #f8f9fa; border-radius: 8px;">
                   <a class="btn btn-outline-primary btn-sm" target="_blank" rel="noopener"
                     href="{{#if embed_url}}{{embed_url}}{{else}}https://iframe.mediadelivery.net/embed/{{../../bunny_stream_library_id}}/{{video_url}}?autoplay=false{{/if}}">
                              <i class="fas fa-external-link-alt me-2"></i>Open Video
                            </a>
                            <div class="small text-muted mt-2">Inline player disabled</div>
                          </div>
                        {{else}}
                        <div class="video-container mb-3" data-video-url="{{video_url}}" data-video-type="{{video_type}}" data-library-id="{{../../bunny_stream_library_id}}">
                          <div class="video-loading text-center p-3" style="background-color: #f8f9fa; border-radius: 8px;">
                            <div class="spinner-border spinner-border-sm text-danger mb-2" role="status">
                              <span class="visually-hidden">Loading...</span>
                            </div>
                            <div class="small text-muted">Loading video...</div>
                          </div>
                          <div class="video-player" style="display: none;">
                            <div class="ratio ratio-16x9">
                              <iframe
                                data-src="{{#if embed_url}}{{embed_url}}{{else}}https://iframe.mediadelivery.net/embed/{{../../bunny_stream_library_id}}/{{video_url}}?autoplay=false{{/if}}"
                                frameborder="0" 
                                allowfullscreen
                                allow="accelerometer; gyroscope; encrypted-media; picture-in-picture;"
                                loading="lazy"
                                class="rounded">
                              </iframe>
                            </div>
                          </div>
                          <div class="video-error text-center p-3" style="display: none; background-color: #f8d7da; border-radius: 8px;">
                            <div class="small text-danger">
                              <i class="fas fa-exclamation-triangle me-1"></i>
                              Video processing in progress. <a href="javascript:void(0)" onclick="retryVideo(this)">Retry</a>
                            </div>
                          </div>
                        </div>
                        {{/if}}
                        {{#if youtube_video_url}}
                        <div class="alert alert-info small py-2 mb-3" role="alert">
                          <i class="fab fa-youtube me-1"></i>
                          Also available on YouTube: <a href="{{youtube_video_url}}" target="_blank" rel="noopener">open</a>
                        </div>
                        {{else if ../../youtube_ready}}
                        <form method="POST" action="/projects/{{../../project.id}}/auditions/{{id}}/upload-to-youtube" class="mt-2">
                          <input type="hidden" name="redirect" value="{{../../redirect_to}}">
                          <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                            <i class="fab fa-youtube me-1"></i>Upload to YouTube
                          </button>
                        </form>
                        {{/if}}
                        {{else}}
                        <div class="text-center p-3 mb-3" style="background-color: #f8f9fa; border-radius: 8px;">
                          <i class="fas fa-video-slash text-muted mb-2"></i>
                          <div class="small text-danger">No valid Bunny.net video ID found. Please check the submission or contact support.</div>
                        </div>
                        {{/if}}
                      {{else}}
                      <!-- No Video -->
                      <div class="text-center p-3 mb-3" style="background-color: #f8f9fa; border-radius: 8px;">
                        <i class="fas fa-video-slash text-muted mb-2"></i>
                        <div class="small text-muted">No video submitted</div>
                      </div>
                      {{/if}}
                      
                      <!-- Additional Info -->
                      {{#if age}}
                      <p class="card-text small mb-1 edit-field">
                        <strong>Age:</strong> <span class="edit-display">{{age}}</span>
                        <input type="number" class="form-control form-control-sm d-none edit-input" placeholder="Age" data-field="age" value="{{age}}" style="margin-top: 0.5rem;">
                      </p>
                      {{/if}}
                      {{#if height}}
                      <p class="card-text small mb-1 edit-field">
                        <strong>Height:</strong> <span class="edit-display">{{height}}</span>cm
                        <input type="number" class="form-control form-control-sm d-none edit-input" placeholder="Height (cm)" data-field="height" value="{{height}}" style="margin-top: 0.5rem;">
                      </p>
                      {{/if}}
                      <p class="card-text small mb-1 edit-field">
                        <strong>Based in:</strong> <span class="edit-display">{{#if current_location}}{{current_location}}{{else}}—{{/if}}</span>
                        <textarea class="form-control form-control-sm d-none edit-input" placeholder="Location" data-field="current_location" rows="2" style="margin-top: 0.5rem;">{{current_location}}</textarea>
                      </p>
                      <p class="card-text small mb-1 edit-field">
                        <strong>About me:</strong> <span class="edit-display">{{#if about_me}}{{about_me}}{{else}}—{{/if}}</span>
                        <textarea class="form-control form-control-sm d-none edit-input" placeholder="About me" data-field="about_me" rows="3" style="margin-top: 0.5rem;">{{about_me}}</textarea>
                      </p>
                       
                      <!-- Video URLs -->
                      <p class="card-text small mb-1 edit-field">
                        <strong>Bunny URL:</strong>
                        <span class="edit-display">{{#if (eq video_type "bunny_stream")}}<code class="small">{{video_url}}</code>{{/if}}</span>
                        <input type="url" class="form-control form-control-sm d-none edit-input" placeholder="Video URL" data-field="video_url" value="{{video_url}}" style="margin-top: 0.5rem;" />
                      </p>

                      <p class="card-text small mb-1">
                        <strong>YouTube URL:</strong>
                        <span>{{#if youtube_video_url}}<code class="small">{{youtube_video_url}}</code>{{else if (eq video_type "youtube")}}<code class="small">{{video_url}}</code>{{/if}}</span>
                      </p>
                       
                      <p class="card-text"><small class="text-muted">Submitted: {{created_at_formatted}}</small></p>
                      
                      <!-- Edit/Save/Cancel buttons -->
                      <div class="d-flex gap-2 mt-3 audition-card-edit-buttons">
                        <button type="button" class="btn btn-outline-primary btn-sm w-100 edit-audition-btn card-edit-action-btn d-none" style="display: none;">
                          <i class="fas fa-edit me-1"></i>Edit
                        </button>
                        <button type="button" class="btn btn-success btn-sm flex-grow-1 save-audition-btn card-save-btn d-none">
                          <i class="fas fa-check me-1"></i>Save
                        </button>
                        <button type="button" class="btn btn-secondary btn-sm flex-grow-1 cancel-audition-btn card-cancel-btn d-none">
                          <i class="fas fa-times me-1"></i>Cancel
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
                  {{/each}}
                </div>
              {{else}}
                <p class="text-muted mb-0">No auditions submitted for this role yet.</p>
              {{/if}}
            </div>
          </div>
        </div>
      {{/each}}
    </div>
  {{else}}
    <p>No matching roles found for the selected filter.</p>
  {{/if}}
  </div>

  <a href="/projects" class="btn btn-outline-danger mt-4">Back to Projects</a>
</div>

