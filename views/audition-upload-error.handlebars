{{!-- Upload error page --}}
<style>
  body {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    margin: 0;
    padding: 20px;
  }
  
  .error-container {
    background: white;
    border-radius: 12px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    padding: 60px 40px;
    max-width: 600px;
    text-align: center;
  }
  
  .error-icon {
    width: 80px;
    height: 80px;
    background: #ff6b6b;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 30px;
    font-size: 48px;
  }
  
  h1 {
    color: #333;
    font-size: 32px;
    margin: 0 0 15px;
    font-weight: 600;
  }
  
  .error-message {
    color: #666;
    font-size: 16px;
    line-height: 1.6;
    margin-bottom: 30px;
  }
  
  .error-details {
    background: #f5f5f5;
    border-left: 4px solid #ff6b6b;
    padding: 15px;
    border-radius: 4px;
    text-align: left;
    margin-bottom: 30px;
    font-family: 'Courier New', monospace;
    font-size: 12px;
    color: #555;
    max-height: 150px;
    overflow-y: auto;
  }
  
  .contact-info {
    background: #e8f4f8;
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 30px;
  }
  
  .contact-info h3 {
    color: #2c3e50;
    margin: 0 0 10px;
    font-size: 18px;
  }
  
  .contact-info p {
    color: #34495e;
    margin: 8px 0;
    font-size: 14px;
  }
  
  .contact-email {
    color: #3498db;
    text-decoration: none;
    font-weight: 600;
    font-size: 16px;
  }
  
  .contact-email:hover {
    text-decoration: underline;
  }
  
  .button-group {
    display: flex;
    gap: 15px;
    justify-content: center;
    flex-wrap: wrap;
  }
  
  .btn {
    padding: 12px 30px;
    border-radius: 6px;
    border: none;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: all 0.3s ease;
  }
  
  .btn-primary {
    background: #667eea;
    color: white;
  }
  
  .btn-primary:hover {
    background: #5568d3;
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(102, 126, 234, 0.2);
  }
  
  .btn-secondary {
    background: #ecf0f1;
    color: #34495e;
  }
  
  .btn-secondary:hover {
    background: #d5dbdb;
  }
  
  .timestamp {
    color: #999;
    font-size: 12px;
    margin-top: 20px;
  }
</style>

<div class="error-container">
  <div class="error-icon">❌</div>
  
  <h1>Oops! Upload Failed</h1>
  
  <div class="error-message">
    <p>We encountered an issue while uploading your audition video. This usually happens due to network connection problems or server issues.</p>
    <p>Please try the following:</p>
    <ul style="text-align: left; display: inline-block;">
      <li>Refresh the page and try uploading again</li>
      <li>Check your internet connection</li>
      <li>Make sure the video file isn't corrupted</li>
      <li>Try a different web browser</li>
    </ul>
  </div>
  
  {{#if errorDetails}}
  <div class="error-details">
    <strong>Error Details:</strong><br>
    {{errorDetails}}
  </div>
  {{/if}}
  
  <div class="contact-info">
    <h3>Need Help?</h3>
    <p>If you continue to experience issues, please contact the administrator:</p>
    <p>
      <strong>Emmanuel Gandelman</strong><br>
      <a href="mailto:emmanuel.gandelman@gmail.com" class="contact-email">emmanuel.gandelman@gmail.com</a>
    </p>
  </div>
  
  <div class="button-group">
    <button class="btn btn-primary" onclick="history.back()">← Go Back</button>
    <a href="/" class="btn btn-secondary">← Back to Home</a>
  </div>
  
  <div class="timestamp">
    Generated at: {{timestamp}}
  </div>
</div>
