<div class="container my-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-1">Agents</h1>
      <p class="text-muted mb-0">Manage the main agency record and any associate contacts underneath it.</p>
    </div>
    <a href="/admin/upload-intents" class="btn btn-outline-secondary btn-sm">Upload Intents</a>
  </div>

  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <form method="POST" action="/admin/agents" class="row g-3">
        <div class="col-md-3">
          <label class="form-label">Hebrew name</label>
          <input class="form-control" name="hebrew_name" required>
        </div>
        <div class="col-md-3">
          <label class="form-label">English name</label>
          <input class="form-control" name="english_name" required>
        </div>
        <div class="col-md-2">
          <label class="form-label">Main phone</label>
          <input class="form-control" name="phone">
        </div>
        <div class="col-md-2">
          <label class="form-label">Main email</label>
          <input class="form-control" name="email">
        </div>
        <div class="col-md-2">
          <label class="form-label">Aliases</label>
          <input class="form-control" name="search_aliases" placeholder="comma, separated spellings">
        </div>
        <div class="col-12">
          <div class="form-text text-muted">
            Use aliases for extra Hebrew/English spellings, nicknames, or common search terms. These are what power the autocomplete matching.
          </div>
        </div>
        <div class="col-12">
          <button class="btn btn-primary">Add agent</button>
        </div>
      </form>
    </div>
  </div>

  <div class="d-flex align-items-center justify-content-between mb-2">
    <h2 class="h5 mb-0">Existing agencies</h2>
    <div class="d-flex align-items-center gap-2">
      <input type="text" class="form-control form-control-sm" id="agent-filter" placeholder="Filter agencies" style="max-width: 260px;">
      <span class="text-muted small">{{agents.length}} total</span>
    </div>
  </div>

  <div id="agent-list">
  {{#each agents}}
  <div class="card shadow-sm mb-3 agent-card">
    <div class="card-body">
      <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
        <div>
          <div class="d-flex align-items-center gap-2 flex-wrap">
            <h3 class="h5 mb-0">{{english_name}}</h3>
            <span class="badge {{#if active}}text-bg-success{{else}}text-bg-secondary{{/if}}">
              {{#if active}}Active{{else}}Inactive{{/if}}
            </span>
          </div>
          <div class="text-muted">{{hebrew_name}}</div>
          <div class="small text-muted mt-1">{{audition_count}} audition{{#unless (eq audition_count 1)}}s{{/unless}}</div>
        </div>
        <div class="text-end">
          <form method="POST" action="/admin/agents/{{id}}/delete" class="d-inline" onsubmit="return confirm('Delete this agency?');">
            <button class="btn btn-outline-danger btn-sm">Delete</button>
          </form>
        </div>
      </div>

      <form method="POST" action="/admin/agents/{{id}}" class="row g-3 align-items-end mb-4">
        <div class="col-md-3">
          <label class="form-label small">Hebrew name</label>
          <input class="form-control form-control-sm" name="hebrew_name" value="{{hebrew_name}}" required>
        </div>
        <div class="col-md-3">
          <label class="form-label small">English name</label>
          <input class="form-control form-control-sm" name="english_name" value="{{english_name}}" required>
        </div>
        <div class="col-md-2">
          <label class="form-label small">Phone</label>
          <input class="form-control form-control-sm" name="phone" value="{{phone}}">
        </div>
        <div class="col-md-2">
          <label class="form-label small">Email</label>
          <input class="form-control form-control-sm" name="email" value="{{email}}">
        </div>
        <div class="col-md-2">
          <label class="form-label small">Aliases</label>
          <input class="form-control form-control-sm" name="search_aliases" value="{{search_aliases}}" placeholder="comma, separated spellings">
        </div>
        <div class="col-md-2">
          <label class="form-label small">Status</label>
          <select class="form-select form-select-sm" name="active">
            <option value="1" {{#if active}}selected{{/if}}>Active</option>
            <option value="0" {{#unless active}}selected{{/unless}}>Inactive</option>
          </select>
        </div>
        <div class="col-12 d-flex gap-2">
          <button class="btn btn-primary btn-sm">Save agency</button>
        </div>
      </form>

      <div class="border-top pt-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <h4 class="h6 mb-0">Associate contacts</h4>
          <span class="text-muted small">{{contacts.length}} contact{{#unless (eq contacts.length 1)}}s{{/unless}}</span>
        </div>

        <div class="row g-3">
          <div class="col-lg-8">
            {{#if contacts.length}}
            <div class="list-group">
              {{#each contacts}}
              <div class="list-group-item">
                <form method="POST" action="/admin/agent-contacts/{{id}}" class="row g-2 align-items-end">
                  <div class="col-md-4">
                    <label class="form-label small">Name</label>
                    <input class="form-control form-control-sm" name="contact_name" value="{{contact_name}}">
                  </div>
                  <div class="col-md-3">
                    <label class="form-label small">Phone</label>
                    <input class="form-control form-control-sm" name="phone" value="{{phone}}">
                  </div>
                  <div class="col-md-3">
                    <label class="form-label small">Email</label>
                    <input class="form-control form-control-sm" name="email" value="{{email}}">
                  </div>
                  <div class="col-md-2 d-flex align-items-center gap-2">
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" value="1" id="edit_is_primary_{{id}}" name="is_primary" {{#if is_primary}}checked{{/if}}>
                      <label class="form-check-label small" for="edit_is_primary_{{id}}">Primary</label>
                    </div>
                  </div>
                  <div class="col-12 d-flex gap-2">
                    <button class="btn btn-primary btn-sm">Save contact</button>
                    <button class="btn btn-outline-danger btn-sm" type="submit" form="delete-contact-{{id}}" onclick="return confirm('Delete this contact?');">Delete</button>
                  </div>
                </form>
                <form id="delete-contact-{{id}}" method="POST" action="/admin/agent-contacts/{{id}}/delete"></form>
              </div>
              {{/each}}
            </div>
            {{else}}
            <div class="text-muted small">No associate contacts yet.</div>
            {{/if}}
          </div>
          <div class="col-lg-4">
            <form method="POST" action="/admin/agents/{{id}}/contacts" class="card border-0 bg-light">
              <div class="card-body">
                <h5 class="h6">Add associate</h5>
                <div class="mb-2">
                  <label class="form-label small">Name</label>
                  <input class="form-control form-control-sm" name="contact_name">
                </div>
                <div class="mb-2">
                  <label class="form-label small">Phone</label>
                  <input class="form-control form-control-sm" name="phone">
                </div>
                <div class="mb-2">
                  <label class="form-label small">Email</label>
                  <input class="form-control form-control-sm" name="email">
                </div>
                <div class="form-check mb-3">
                  <input class="form-check-input" type="checkbox" value="1" id="is_primary_{{id}}" name="is_primary">
                  <label class="form-check-label small" for="is_primary_{{id}}">Mark as primary contact</label>
                </div>
                <button class="btn btn-outline-primary btn-sm">Add associate</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
  {{/each}}
  </div>
</div>

<script>
  (function () {
    const input = document.getElementById('agent-filter');
    const cards = Array.from(document.querySelectorAll('.agent-card'));
    if (!input || !cards.length) return;
    input.addEventListener('input', () => {
      const query = (input.value || '').trim().toLowerCase();
      cards.forEach((card) => {
        card.style.display = card.textContent.toLowerCase().includes(query) ? '' : 'none';
      });
    });
  })();
</script>
